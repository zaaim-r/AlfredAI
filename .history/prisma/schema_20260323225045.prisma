// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum AccountType {
  checking
  savings
  credit
  brokerage
}

enum TransactionStatus {
  pending
  posted
}

enum SubscriptionStatus {
  pending
  confirmed
  dismissed
}

enum SubscriptionFrequency {
  weekly
  monthly
  annual
}

enum RolloverAction {
  rollover
  save
  redistribute
  reset
}

enum NotificationType {
  category_warning
  category_alert
  ai_insight
  rollover_prompt
  monthly_summary
  new_subscription
}

enum PayFrequency {
  weekly
  biweekly
  semi_monthly
  monthly
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id                       String    @id // Clerk user ID
  email                    String    @unique
  timezone                 String    @default("America/New_York")
  alfred_memory            Json?
  alfred_context_snapshot  Json?
  snapshot_updated_at      DateTime?
  created_at               DateTime  @default(now())

  accounts      Account[]
  notifications Notification[]
  income        IncomeSource[]
  subscriptions Subscription[]
  bill_splits   BillSplit[]
  savings       SavingsBucket?
  categories    Category[]
}

// ─────────────────────────────────────────
// ACCOUNT
// ─────────────────────────────────────────

model Account {
  id                   String      @id @default(cuid())
  user_id              String
  teller_account_id    String      @unique
  teller_access_token  String
  name                 String
  institution_name     String
  type                 AccountType
  current_balance      Decimal     @db.Decimal(12, 2)
  last_synced_at       DateTime?
  is_active            Boolean     @default(true)
  deleted_at           DateTime?
  created_at           DateTime    @default(now())

  user         User          @relation(fields: [user_id], references: [id])
  transactions Transaction[]
}

// ─────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────

model Category {
  id                String   @id @default(cuid())
  user_id           String?  // null = system category
  name              String
  monthly_limit     Decimal? @db.Decimal(12, 2)
  warning_threshold Int      @default(80)
  is_system         Boolean  @default(false)
  color             String   @default("#6366f1")
  icon              String   @default("circle")
  rollover_history  Json?
  deleted_at        DateTime?
  created_at        DateTime @default(now())

  user         User?         @relation(fields: [user_id], references: [id])
  transactions Transaction[]
}

// ─────────────────────────────────────────
// TRANSACTION
// ─────────────────────────────────────────

model Transaction {
  id                     String            @id @default(cuid())
  user_id                String
  account_id             String
  teller_transaction_id  String?           @unique
  date                   DateTime
  amount                 Decimal           @db.Decimal(12, 2)
  merchant_name          String
  category_id            String
  status                 TransactionStatus @default(posted)
  is_excluded            Boolean           @default(false)
  is_transfer            Boolean           @default(false)
  is_manual              Boolean           @default(false)
  created_at             DateTime          @default(now())

  account  Account  @relation(fields: [account_id], references: [id])
  category Category @relation(fields: [category_id], references: [id])

  @@index([user_id, date])
  @@index([user_id, category_id])
  @@index([account_id])
}

// ─────────────────────────────────────────
// NET WORTH SNAPSHOT
// ─────────────────────────────────────────

model NetWorthSnapshot {
  id                String   @id @default(cuid())
  user_id           String
  date              DateTime
  total_assets      Decimal  @db.Decimal(12, 2)
  total_liabilities Decimal  @db.Decimal(12, 2)
  net_worth         Decimal  @db.Decimal(12, 2)
  created_at        DateTime @default(now())

  @@index([user_id, date])
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  user_id    String
  type       NotificationType
  title      String
  body       String
  is_read    Boolean          @default(false)
  metadata   Json?
  created_at DateTime         @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, is_read])
}

// ─────────────────────────────────────────
// INCOME SOURCE
// ─────────────────────────────────────────

model IncomeSource {
  id            String   @id @default(cuid())
  user_id       String
  name          String
  amount        Decimal  @db.Decimal(12, 2)
  frequency     PayFrequency
  schedule      Json?    // { pay_days: [1, 15] } for semi_monthly
  next_pay_date DateTime
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

// ─────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────

model Subscription {
  id              String                @id @default(cuid())
  user_id         String
  merchant_name   String
  amount          Decimal               @db.Decimal(12, 2)
  frequency       SubscriptionFrequency
  last_charged_at DateTime
  status          SubscriptionStatus    @default(pending)
  created_at      DateTime              @default(now())

  user User @relation(fields: [user_id], references: [id])
}

// ─────────────────────────────────────────
// BILL SPLIT
// ─────────────────────────────────────────

model BillSplit {
  id                String   @id @default(cuid())
  user_id           String
  receipt_image_url String
  subtotal          Decimal  @db.Decimal(12, 2)
  tax               Decimal  @db.Decimal(12, 2)
  tip               Decimal  @db.Decimal(12, 2)
  total             Decimal  @db.Decimal(12, 2)
  split_data        Json
  transaction_id    String?
  created_at        DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

// ─────────────────────────────────────────
// SAVINGS BUCKET
// ─────────────────────────────────────────

model SavingsBucket {
  id         String   @id @default(cuid())
  user_id    String   @unique
  balance    Decimal  @default(0) @db.Decimal(12, 2)
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id])
}